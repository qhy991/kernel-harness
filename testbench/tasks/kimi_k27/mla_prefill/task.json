{
  "name": "mla_prefill",
  "op": "MLA prefill attention",
  "phase": "prefill",
  "family": "mla-attention",
  "num_heads": 64,
  "qk_head_dim": 192,
  "v_head_dim": 128,
  "sweep": [
    512,
    1024,
    2048,
    4096,
    8192,
    16384,
    32768
  ],
  "backend": "flashinfer BatchPrefillWithRaggedKVCacheWrapper (blackwell)",
  "tolerance": {
    "max_atol": 0.1,
    "max_rtol": 0.05,
    "required_matched_ratio": 0.98
  },
  "baseline": {
    "source": "live",
    "measure": "reference.py timed by sol-execbench CUPTI (median device-kernel us)",
    "denominator": "the live per-shape reference latency (see .baseline_cache.json)"
  }
}