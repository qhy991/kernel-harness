# Optional external-checkout overrides. Relative paths resolve from the repository root.
# Single SGLang source for every model/task (including MiniMax-M3 DSA).
SGLANG_DIR=../sglang
CUDA_HOME=/usr/local/cuda
AITER_PATH=../aiter

# Backend selection. Only the CUDA/B200 + DeepGEMM bundle is registered today.
# ROCm combinations fail loudly until an AMD provider is added.
KERNEL_HARNESS_PLATFORM=cuda
KERNEL_HARNESS_PROFILE=cuda-b200
KERNEL_HARNESS_PROVIDER=deep-gemm-sgl-kernel
KERNEL_HARNESS_TIMER=auto
